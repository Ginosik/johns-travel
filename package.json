{
  "name": "johns-travel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run check:portuguese && vite build",
    "check:portuguese": "node scripts/check-portuguese.mjs",
    "elevenlabs:dry-run": "node scripts/elevenlabs-generate-audio.mjs --dry-run",
    "elevenlabs:generate": "node scripts/elevenlabs-generate-audio.mjs",
    "elevenlabs:voices": "node scripts/elevenlabs-voices.mjs",
    "google-tts:dry-run": "node scripts/google-tts-generate-audio.mjs --dry-run",
    "google-tts:generate": "node scripts/google-tts-generate-audio.mjs",
    "preview": "vite preview",
    "export:dry-run": "node scripts/export-dry-run.mjs",
    "record:post": "node scripts/record-conversation.mjs",
    "record:post:audio": "node scripts/record-conversation-with-audio.mjs",
    "record:day1:audio": "node scripts/record-conversation-with-audio.mjs --post day-1 --output day-1-audio --format youtube --captions translation",
    "record:day1:audio:all": "node scripts/record-conversation-with-audio.mjs --post day-1 --output day-1-audio --format all --captions translation",
    "record:day2:audio": "node scripts/record-conversation-with-audio.mjs --post day-2 --output day-2-audio --format youtube --captions translation",
    "record:hindi": "node scripts/record-conversation.mjs --post hindi-1 --output hindi-1",
    "review:export": "node scripts/review-export.mjs",
    "test": "node scripts/run-playwright.mjs",
    "test:ui": "node scripts/run-playwright.mjs --ui",
    "test:headed": "node scripts/run-playwright.mjs --headed",
    "test:debug": "node scripts/run-playwright.mjs --debug",
    "test:report": "node node_modules/@playwright/test/cli.js show-report"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "@xyflow/react": "^12.11.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.0",
    "vite": "^5.4.21"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0"
  }
}
