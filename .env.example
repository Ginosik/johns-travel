# ElevenLabs text-to-speech generation
# Copy to .env and fill in values. .env is ignored by git.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_JOHN=
ELEVENLABS_VOICE_NICKY=
ELEVENLABS_VOICE_MARIANA=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.52
ELEVENLABS_SIMILARITY_BOOST=0.78
ELEVENLABS_STYLE=0.18
ELEVENLABS_SPEAKER_BOOST=true

# Mariana Destrava voice: higher stability keeps the model answers consistent.
ELEVENLABS_MARIANA_STABILITY=0.82
ELEVENLABS_MARIANA_SIMILARITY_BOOST=0.86
ELEVENLABS_MARIANA_STYLE=0.05
ELEVENLABS_MARIANA_SPEAKER_BOOST=true
